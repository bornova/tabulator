{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": false,
    "declaration": true,
    "emitDeclarationOnly": true,
    "noEmitOnError": false,
    "declarationMap": false,
    "outDir": "./dist/types",
    "rootDir": "./src/js",
    "stripInternal": true,
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "target": "ES2020"
  },
  "include": ["src/js/builds/esm.js"]
}
