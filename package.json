{
  "name": "@bornova/tabulator",
  "version": "1.0.0",
  "description": "Feature-rich interactive data tables with zero dependencies",
  "style": "dist/css/themes/default/tabulator.css",
  "type": "module",
  "main": "dist/js/browser/tabulator.js",
  "module": "dist/js/esm/tabulator.js",
  "exports": {
    ".": {
      "browser": "./dist/js/browser/tabulator.js",
      "import": "./dist/js/esm/tabulator.js",
      "default": "./dist/js/esm/tabulator.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "prebuild": "npm run prettier && npm run lint",
    "build": "rollup -c",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "prettier": "prettier . --check ",
    "pretest": "playwright install chromium --with-deps",
    "test": "npm run build && playwright test"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/bornova/tabulator.git"
  },
  "author": "Oli Folkerd",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/bornova/tabulator/issues"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@rollup/plugin-terser": "^1.0.0",
    "eslint": "^10.2.1",
    "globals": "^17.5.0",
    "globby": "^16.2.0",
    "prettier": "^3.8.3",
    "rollup": "^4.60.2",
    "sass": "^1.99.0"
  }
}
