{
  "name": "tabulator-tables",
  "version": "6.3.1",
  "description": "Interactive table generation JavaScript library",
  "style": "dist/css/themes/default/tabulator.css",
  "type": "module",
  "main": "dist/js/browser/tabulator.js",
  "module": "dist/js/esm/tabulator.js",
  "types": "dist/types/builds/esm.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/builds/esm.d.ts",
      "require": "./dist/js/browser/tabulator.js",
      "import": "./dist/js/esm/tabulator.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "prebuild": "npm run prettier && npm run lint",
    "build": "npm run build:css && npm run build:js && npm run build:types",
    "build:css": "node ./scripts/build-css.js",
    "build:js": "node ./scripts/build-js.js",
    "build:types": "tsc -p ./tsconfig.types.json",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "prettier": "prettier . --check ",
    "pretest": "playwright install chromium --with-deps",
    "test": "npm run build && playwright test"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/olifolkerd/tabulator.git"
  },
  "author": "Oli Folkerd",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/olifolkerd/tabulator/issues"
  },
  "homepage": "https://tabulator.info/",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "esbuild": "^0.27.3",
    "eslint": "^10.0.3",
    "fs-extra": "^11.3.4",
    "globals": "^17.4.0",
    "globby": "^16.1.1",
    "prettier": "^3.8.1",
    "sass": "^1.98.0",
    "typescript": "^5.9.3"
  }
}
