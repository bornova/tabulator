{
  "name": "@bornova/tabulator-tables",
  "description": "Feature-rich interactive data tables with zero dependencies",
  "version": "1.0.1",
  "license": "MIT",
  "keywords": [
    "table",
    "datagrid",
    "data-table",
    "grid",
    "spreadsheet",
    "interactive",
    "filter",
    "sort",
    "pagination",
    "editable"
  ],
  "style": "./dist/css/themes/default/tabulator.min.css",
  "type": "module",
  "module": "./dist/js/esm/tabulator.js",
  "types": "./dist/types/builds/esm.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/builds/esm.d.ts",
      "import": "./dist/js/esm/tabulator.js"
    }
  },
  "jsdelivr": "./dist/js/browser/tabulator.min.js",
  "unpkg": "./dist/js/browser/tabulator.min.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/bornova/tabulator.git"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "prebuild": "npm run prettier && npm run lint",
    "build": "rollup -c && npm run build:types",
    "build:types": "tsc",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "prettier": "prettier . --check ",
    "pretest": "playwright install chromium --with-deps",
    "test": "npm run build && playwright test"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@rollup/plugin-terser": "^1.0.0",
    "eslint": "^10.4.1",
    "globals": "^17.6.0",
    "globby": "^16.2.0",
    "prettier": "^3.8.3",
    "rollup": "^4.60.4",
    "sass": "^1.100.0",
    "typescript": "^6.0.3"
  }
}
